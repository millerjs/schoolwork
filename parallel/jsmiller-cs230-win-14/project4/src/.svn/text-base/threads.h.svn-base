#ifndef THREADS_H_
#define THREADS_H_

#include <pthread.h>
#include "../src/locks.h"
#include "q.h"
/* #include "firewall.h" */

#ifndef _LOOP_T
#define _LOOP_T
typedef void *(*loop_t)(void*);
#endif

extern volatile int N_PER_THREAD;

typedef struct thread_arg_t {
    pthread_t *this;
    int n;
    int id;
    int loop;
    long test_counter;
    
    LQ_t **qs;
    
    int nsources;

    long *counter;
    Lock *lock;
} thread_arg_t;

/* The main worker loop for this project */

/* Creates and spaws a pool of n threads */
thread_arg_t **create_thread_pool(Lock *lock, loop_t loop, long *counter, int n);

/* Joins all threads in array threads */
int join_thread_pool(thread_arg_t **threads, int n);

int assign_queues(Lock *locks, thread_arg_t ** threads, int n, LQ_t **qs, int numPackets);

void start_threads();
void stop_threads();

void *time_based_loop(void* _args_);
void *work_based_loop(void* _args_);


#endif

