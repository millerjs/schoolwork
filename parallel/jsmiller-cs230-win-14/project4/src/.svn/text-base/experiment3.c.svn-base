#include <stdlib.h>
#include <ctype.h>
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <time.h>
#include <sys/types.h>
#include <sys/stat.h>

#include "threads.h"
#include "util.h"
#include "locks.h"
#include "../../utils/stopwatch.h"

#define MAX_PATH 1028
long loop_threaded(int n_tests, int n_threads, Lock *lock, void*(*loop)(void*), int param1);

int experiment3(FILE *output_file)
{

    int threads[] = {1, 2, 4, 8, 16, 32, 64, 0};

    Lock lock;
    int n_threads = 8;
    long count = 0;
    int time = 50000;
    int n_times = 4;

    int max = 0;
    int argmax_min = 0;
    int argmax_max = 0;

    fprintf(output_file, "Experiment 3\n");
    fprintf(output_file, "lock\tthreads\tcount\tmillisecods\tmind_d\tmax_d\n");

    int reoptimize = 1;

    if (reoptimize){

        /* Control run */
        null_init(&lock);
        count = loop_threaded(n_times, 1, &lock, &time_based_loop, time);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "none", n_threads, count, time);
        fprintf(stderr, "%s\t%d\t%li\t%d\n", "none", n_threads, count, time);
    
        for (int min_d = 1; min_d < 500; min_d *= 2){
            for (int max_d = min_d + 1; max_d < 5000; max_d *= 2){

                /* tasb run */
                TASB_init(&lock, min_d, max_d);
                count = loop_threaded(n_times, n_threads, &lock, &time_based_loop, time);
                fprintf(output_file, "%s\t%d\t%li\t%d\t%d\t%d\n", "TASB", 
                        n_threads, count, time, min_d, max_d);
                fprintf(stderr, "%s\t%d\t%li\t%d\t%d\t%d\n", "TASB", 
                        n_threads, count, time, min_d, max_d);

                if (count > max){
                    argmax_max = max_d;
                    argmax_min = min_d;
                    max = (int)count;
                }

                fflush(output_file);

            }
        }

        fprintf(stderr, "Optimal\n");
        fprintf(stderr, "%s\t%d\t%d\t%d\t%d\t%d\n", "TASB", 
                n_threads, max, time, argmax_min, argmax_max);
        fprintf(output_file, "Optimal\n");
        fprintf(output_file, "%s\t%d\t%d\t%d\t%d\t%d\n", "TASB", 
                n_threads, max, time, argmax_min, argmax_max);
        
    }

    null_init(&lock);
    count = loop_threaded(n_times, 1, &lock, &time_based_loop, time);
    fprintf(output_file, "%s\t%d\t%li\t%d\n", "none", n_threads, count, time);
    
    for (int i = 0; threads[i]; i++){
        n_threads = threads[i];

        DEBUG("clh: %d", n_threads);

        CLH_init(&lock, MAX_THREADS);
        count = loop_threaded(n_times, n_threads, &lock, &time_based_loop, time);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "CLH", n_threads, count, time);
        
        DEBUG("tas");

        TAS_init(&lock);
        count = loop_threaded(n_times, n_threads, &lock, &time_based_loop, time);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "TAS", n_threads, count, time);

        DEBUG("tasb");
        
        TASB_init(&lock, argmax_min, argmax_max);
        count = loop_threaded(n_times, n_threads, &lock, &time_based_loop, time);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "TASB", n_threads, count, time);

        DEBUG("mutex");
        
        mutex_init(&lock);
        count = loop_threaded(n_times, n_threads, &lock, &time_based_loop, time);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "mutex", n_threads, count, time);

        DEBUG("alock");

        ALOCK_init(&lock, n_threads);
        count = loop_threaded(n_times, n_threads, &lock, &time_based_loop, time);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "ALOCK", n_threads, count, time);


        fflush(output_file);
        
    }
    
    
    return 0;
}
