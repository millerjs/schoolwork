#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <signal.h>
#include <math.h>

#include "../../utils/generators.h"
#include "../../utils/stopwatch.h"
#include "../../utils/fingerprint.h"
#include "../../utils/packetsource.h"

#include "firewall.h"

long fingerprint = 0;


#define MS_TO_RUN 2000;


double serialFirewall (int numPackets,
                       int numSources,
                       long mean,
                       int uniformFlag,
                       short experimentNumber)
{
    PacketSource_t * packetSource = createPacketSource(mean, numSources, experimentNumber);
    StopWatch_t watch;
    fingerprint = 0;

    if( uniformFlag) {
        startTimer(&watch);
        for( int i = 0; i < numSources; i++ ) {
            for( int j = 0; j < numPackets; j++ ) {
                volatile Packet_t * tmp = getUniformPacket(packetSource,i);
                fingerprint += getFingerprint(tmp->iterations, tmp->seed);
            }
        }
        stopTimer(&watch);

    } else {
        startTimer(&watch);
        for( int i = 0; i < numSources; i++ ) {
            for( int j = 0; j < numPackets; j++ ) {
                volatile Packet_t * tmp = getExponentialPacket(packetSource,i);
                fingerprint += getFingerprint(tmp->iterations, tmp->seed);

            }
        }
        stopTimer(&watch);
    }

    return getElapsedTime(&watch);

}

unsigned long getms()
{
    struct timeval tv;       
    if(gettimeofday(&tv, NULL) != 0) return 0;
    return (unsigned long)((tv.tv_sec * 1000ul) + (tv.tv_usec / 1000ul));
}

long parallelFirewall (int numPackets, 
                         int numSources, 
                         long mean, 
                         int uniformFlag, 
                         short experimentNumber, 
                         loop_t loop,
                         Lock *locks)
{
    LOOP = 1;
    START = 0;

    LQ_t **qs = newLQ_array(numSources);
    
    ERROR_IF(!qs, "failed to generate queue array");
    thread_arg_t **threads;
    
    threads = create_thread_pool(NULL, loop, NULL, numSources);

    assign_queues(locks, threads, numSources, qs, numPackets);
    
    PacketSource_t * packetSource = createPacketSource(mean, numSources, experimentNumber);

    START = 1;
    
    unsigned long end = getms() + MS_TO_RUN;

    /* work until the day is done */
    while (getms() < end){

        /* loop through all sources */
        for (int i = 0; i < numSources; i++){

            while (getLQlen(qs[i]) < MAX_Q_LEN){

                if (uniformFlag)
                    enqueue_LQ(qs[i], getUniformPacket(packetSource, i));
                else
                    enqueue_LQ(qs[i], getExponentialPacket(packetSource, i));
            }

        }

    }

    LOOP = 0;

    /* wait for all threads to throw in the towel */
    join_thread_pool(threads, numSources);

    /* accumulate the fingerprint */
    fingerprint = 0;
    long count = 0;
    

    for (int i = 0; i < numSources; i++){
        count += qs[i]->ncomplete;
        fingerprint += qs[i]->fingerprint;
        free_LQ(qs[i]);
    }

    return count;

}

void * lock_free(void* _args_)
{

    volatile Packet_t packet;
    thread_arg_t * args = (thread_arg_t*) _args_;

    int id = args->id;
    LQ_t **qs = args->qs;

    ERROR_IF(!qs, "thread was passed a null queue");

    while (args->qs[id]->ncomplete < args->qs[id]->npackets){

        while (dequeue_LQ(qs[id], &packet)){
            if (args->qs[id]->ncomplete >= args->qs[id]->npackets){
                return NULL; 
            }
        }
        args->qs[id]->fingerprint += getFingerprint(packet.iterations, packet.seed);
        args->qs[id]->ncomplete ++;

    }

    return NULL;

}


void * home_queue(void* _args_)
{

    volatile Packet_t packet;
    thread_arg_t * args = (thread_arg_t*) _args_;

    ERROR_IF(!args, "args");

    int id = args->id;

    while(!START) usleep(1);;

    while (LOOP){

        args->qs[id]->lock->acquire(args->qs[id]->lock);

        if (!dequeue_LQ(args->qs[id], &packet)){
            args->qs[id]->fingerprint += getFingerprint(packet.iterations, packet.seed);
            args->qs[id]->ncomplete ++;
        }
        
        args->qs[id]->lock->release(args->qs[id]->lock);
        
    }

    return NULL;

}



void * random_queue(void* _args_)
{

    volatile Packet_t packet;
    thread_arg_t * args = (thread_arg_t*) _args_;

    ERROR_IF(!args, "args");

    while(!START) usleep(1);;

    while (LOOP){

        int id = RANDOM(0, args->nsources);

        args->qs[id]->lock->acquire(args->qs[id]->lock);

        if (!dequeue_LQ(args->qs[id], &packet)){
            args->qs[id]->fingerprint += getFingerprint(packet.iterations, packet.seed);
            args->qs[id]->ncomplete ++;
        }
        
        args->qs[id]->lock->release(args->qs[id]->lock);
        
    }

    return NULL;

}

void * last_queue(void* _args_)
{

    volatile Packet_t packet;
    thread_arg_t * args = (thread_arg_t*) _args_;

    ERROR_IF(!args, "args");

    while(!START) usleep(1);;

    while (LOOP){

        int id = RANDOM(0, args->nsources);

        if (!args->qs[id]->lock->trylock(args->qs[id]->lock)){

            if (!dequeue_LQ(args->qs[id], &packet)){
                args->qs[id]->fingerprint += getFingerprint(packet.iterations, packet.seed);
                args->qs[id]->ncomplete ++;
            }
        
            args->qs[id]->lock->release(args->qs[id]->lock);
        }
        
    }

    return NULL;

}

void * awesome(void* _args_)
{

    volatile Packet_t packet;
    thread_arg_t * args = (thread_arg_t*) _args_;

    ERROR_IF(!args, "args");

    int id = args->id;

    while(!START) usleep(1);;

    while (LOOP){

        id = (id +1) % args->nsources;

        if (!args->qs[id]->lock->trylock(args->qs[id]->lock)){

            if (!dequeue_LQ(args->qs[id], &packet)){
                args->qs[id]->fingerprint += getFingerprint(packet.iterations, packet.seed);
                args->qs[id]->ncomplete ++;
            }
        
            args->qs[id]->lock->release(args->qs[id]->lock);
        }
        
    }

    return NULL;

}

