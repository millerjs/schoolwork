#include <stdlib.h>
#include <ctype.h>
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <time.h>
#include <sys/types.h>
#include <sys/stat.h>

#include "threads.h"
#include "util.h"
#include "locks.h"
#include "../../utils/stopwatch.h"



#define MAX_PATH 1028

long loop_threaded(int n_tests, int n_threads, Lock *lock, void*(*loop)(void*), int param1);

int experiment1(FILE *output_file, int ms)
{

    Lock lock;
    long c;
    int us = 1000*ms;

    fprintf(output_file, "Experiment 1\n");
    fprintf(output_file, "lock\tthreads\tcount\tmillisecods\n");

    CLH_init(&lock, MAX_THREADS);
    c = loop_threaded(5, 1, &lock, &time_based_loop, us);
    fprintf(output_file, "%s\t%d\t%li\t%d\n", "CLH", 1, c, ms);

    null_init(&lock);
    c = loop_threaded(5, 1, &lock, &time_based_loop, us);
    fprintf(output_file, "%s\t%d\t%li\t%d\n", "none", 1, c, ms);
    
    TAS_init(&lock);
    c = loop_threaded(5, 1, &lock, &time_based_loop, us);
    fprintf(output_file, "%s\t%d\t%li\t%d\n", "TAS", 1, c, ms);

    TASB_init(&lock, 1, 50);
    c = loop_threaded(5, 1, &lock, &time_based_loop, us);
    fprintf(output_file, "%s\t%d\t%li\t%d\n", "TASB", 1, c, ms);

    mutex_init(&lock);
    c = loop_threaded(5, 1, &lock, &time_based_loop, us);
    fprintf(output_file, "%s\t%d\t%li\t%d\n", "mutex", 1, c, ms);

    ALOCK_init(&lock, 1);
    c = loop_threaded(5, 1, &lock, &time_based_loop, us);
    fprintf(output_file, "%s\t%d\t%li\t%d\n", "ALOCK", 1, c, ms);

    return c;
}



