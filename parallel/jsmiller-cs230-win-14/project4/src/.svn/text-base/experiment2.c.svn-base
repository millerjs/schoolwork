#include <stdlib.h>
#include <ctype.h>
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <time.h>
#include <sys/types.h>
#include <sys/stat.h>

#include "threads.h"
#include "util.h"
#include "locks.h"
#include "../../utils/stopwatch.h"

#define MAX_PATH 1028
long loop_threaded(int n_tests, int n_threads, Lock *lock, void*(*loop)(void*), int param1);

int experiment2(FILE *output_file, int count)
{

    Lock lock;
    long t = 10000;

    fprintf(output_file, "Experiment 2\n");
    fprintf(output_file, "lock\tthreads\tcount\tmillisecods\n");

    CLH_init(&lock, 1);
    t = loop_threaded(100, 1, &lock, &work_based_loop, count);
    fprintf(output_file, "%s\t%d\t%d\t%li\n", "CLH", 1, count, t);
    
    null_init(&lock);
    t = loop_threaded(100, 1, &lock, &work_based_loop, count);
    fprintf(output_file, "%s\t%d\t%d\t%li\n", "none", 1, count, t);
    
    TAS_init(&lock);
    t = loop_threaded(100, 1, &lock, &work_based_loop, count);
    fprintf(output_file, "%s\t%d\t%d\t%li\n", "TAS", 1, count, t);

    TASB_init(&lock, 1, 1000);
    t = loop_threaded(100, 1, &lock, &work_based_loop, count);
    fprintf(output_file, "%s\t%d\t%d\t%li\n", "TASB", 1, count, t);

    mutex_init(&lock);
    t = loop_threaded(100, 1, &lock, &work_based_loop, count);
    fprintf(output_file, "%s\t%d\t%d\t%li\n", "mutex", 1, count, t);

    ALOCK_init(&lock, 1);
    t = loop_threaded(100, 1, &lock, &work_based_loop, count);
    fprintf(output_file, "%s\t%d\t%d\t%li\n", "ALOCK", 1, count, t);

    return t;
}

