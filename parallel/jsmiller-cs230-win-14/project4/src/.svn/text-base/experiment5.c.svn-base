#include <stdlib.h>
#include <ctype.h>
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <time.h>
#include <sys/types.h>
#include <sys/stat.h>

#include "threads.h"
#include "util.h"
#include "locks.h"
#include "../../utils/stopwatch.h"
#include "firewall.h"

extern double stddev;

#define MAX_PATH 1028
long loop_threaded(int n_tests, int n_threads, Lock *lock, void*(*loop)(void*), int param1);

int experiment5(FILE *output_file)
{

    Lock lock;
    int n_threads = 8;
    long result = 0;
    int total = 5000000;
    int n_times = 1;

    int argmax_min = 256;
    int argmax_max = 4112;

    fprintf(output_file, "Experiment 5\n");
    fprintf(output_file, "lock\tthreads\tcount\tmicros\n");
    
    null_init(&lock);
    result = loop_threaded(n_times, n_threads, &lock, &time_based_loop, total);
    fprintf(output_file, "%s\t%d\t%li\t%d\t%f\n", "none", n_threads, result, total, stddev);
    fflush(output_file);
    
    n_threads = 31;

    DEBUG("CLH");

    CLH_init(&lock, MAX_THREADS);
    result = loop_threaded(n_times, n_threads, &lock, &time_based_loop, total);
    fprintf(output_file, "%s\t%d\t%li\t%d\t%f\n", "CLH", n_threads, result, total, stddev);
    fflush(output_file);

    DEBUG("TAS");

    TAS_init(&lock);
    result = loop_threaded(n_times, n_threads, &lock, &time_based_loop, total);
    fprintf(output_file, "%s\t%d\t%li\t%d\t%f\n", "TAS", n_threads, result, total, stddev);
    fflush(output_file);
    
    DEBUG("TASB");

    TASB_init(&lock, argmax_min, argmax_max);
    result = loop_threaded(n_times, n_threads, &lock, &time_based_loop, total);
    fprintf(output_file, "%s\t%d\t%li\t%d\t%f\n", "TASB", n_threads, result, total, stddev);
    fflush(output_file);

    DEBUG("mutex");

    mutex_init(&lock);
    result = loop_threaded(n_times, n_threads, &lock, &time_based_loop, total);
    fprintf(output_file, "%s\t%d\t%li\t%d\t%f\n", "mutex", n_threads, result, total, stddev);

    DEBUG("ALOCK");
    fflush(output_file);
    ALOCK_init(&lock, n_threads);
    result = loop_threaded(n_times, n_threads, &lock, &time_based_loop, total);
    fprintf(output_file, "%s\t%d\t%li\t%d\t%f\n", "ALOCK", n_threads, result, total, stddev);


    
    
    return 0;
}



