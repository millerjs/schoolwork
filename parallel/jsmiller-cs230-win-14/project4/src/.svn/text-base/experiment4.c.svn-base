#include <stdlib.h>
#include <ctype.h>
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <time.h>
#include <sys/types.h>
#include <sys/stat.h>

#include "threads.h"
#include "util.h"
#include "locks.h"
#include "../../utils/stopwatch.h"

#define MAX_PATH 1028
long loop_threaded(int n_tests, int n_threads, Lock *lock, void*(*loop)(void*), int param1);

int experiment4(FILE *output_file)
{

    int threads[] = {1, 2, 4, 8, 16, 32, 0, 0};

    Lock lock;
    int n_threads = 8;
    int count = 2<<17;
    int n_counts = 4;

    long result = 0;
    int max = 100000000;
    int argmax_min = 1000000;
    int argmax_max = 1000000;

    fprintf(output_file, "Experiment 4\n");
    fprintf(output_file, "lock\tthreads\ttime\tcount\tmind_d\tmax_d\n");

    int n_times = 1;

    int reoptimize = 1;

    if (reoptimize){

        for (int min_d = 1; min_d < 500; min_d *= 2){
            for (int max_d = min_d + 1; max_d < 5000; max_d *= 2){

                /* tasb run */
                TASB_init(&lock, min_d, max_d);
                result = loop_threaded(n_counts, n_threads, &lock, &work_based_loop, count);
                fprintf(output_file, "%s\t%d\t%li\t%d\t%d\t%d\n", "TASB", 
                        n_threads, result, count, min_d, max_d);
                fprintf(stderr, "%s\t%d\t%li\t%d\t%d\t%d\n", "TASB", 
                        n_threads, result, count, min_d, max_d);

                if (result < max){
                    argmax_max = max_d;
                    argmax_min = min_d;
                    max = (int)count;
                }

                fflush(output_file);
            }
        }

        fprintf(stderr, "Optimal\n");
        fprintf(stderr, "%s\t%d\t%d\t%d\t%d\t%d\n", "TASB", 
                n_threads, max, count, argmax_min, argmax_max);
        fprintf(output_file, "Optimal\n");
        fprintf(output_file, "%s\t%d\t%d\t%d\t%d\t%d\n", "TASB", 
                n_threads, max, count, argmax_min, argmax_max);
        
        
    }

    long c = 0;
    null_init(&lock);
    c = loop_threaded(n_times, 1, &lock, &work_based_loop, count);
    fprintf(output_file, "%s\t%d\t%li\t%d\n", "none", n_threads, c, count);
    
    for (int i = 0; threads[i]; i++){
        n_threads = threads[i];

        DEBUG("clh: %d", n_threads);
        
        CLH_init(&lock, MAX_THREADS);
        c = loop_threaded(n_times, n_threads, &lock, &work_based_loop, count);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "CLH", n_threads, c, count);
        
        DEBUG("tas");

        TAS_init(&lock);
        c = loop_threaded(n_times, n_threads, &lock, &work_based_loop, count);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "TAS", n_threads, c, count);

        DEBUG("tasb");
        
        TASB_init(&lock, argmax_min, argmax_max);
        c = loop_threaded(n_times, n_threads, &lock, &work_based_loop, count);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "TASB", n_threads, c, count);

        DEBUG("mutex");
        
        mutex_init(&lock);
        c = loop_threaded(n_times, n_threads, &lock, &work_based_loop, count);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "mutex", n_threads, c, count);

        DEBUG("alock");

        ALOCK_init(&lock, 512);
        c = loop_threaded(n_times, n_threads, &lock, &work_based_loop, count);
        fprintf(output_file, "%s\t%d\t%li\t%d\n", "ALOCK", n_threads, c, count);



        fflush(output_file);
        
    }
    
    
    return 0;
}
