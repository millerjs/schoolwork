#include <stdlib.h>
#include <unistd.h>
#include <pthread.h>
#include <signal.h>

#include "../src/threads.h"
#include "../src/util.h"
#include "../src/locks.h"

#define GREEN "\033[0;32m"
#define NORM "\033[0m"
#define RED "\033[0;31m"

#define MAX_DESCRIP 1028
#define FAILED 1
#define PASSED 0

extern volatile int START;
extern volatile int LOOP;

int usleep(int msec);
int pthread_kill(pthread_t thread, int signal);

void result(int failed, char* test, char* subtest){
    
    if (failed){
        printf("TEST: [%20s] [%35s] [%s FAILED %s]\n", test, subtest, RED, NORM); 
        return;
    } 
    
    printf("TEST: [%20s] [%35s] [%s PASSED%s ]\n", test, subtest, GREEN, NORM); 
    
}

int test_backoff(){
    int reference[] = {2, 4, 8, 16, 32, 64, 128, 256, 512, 1024};
    int delay_top = 1;
    for (int i = 0; i < 10; i ++){
        delay_top <<= 1;
        if (delay_top != reference[i]){
            result(FAILED, "test_backoff", "verifying exponential backoff");
            return 1;
        }
    }
    
    result(PASSED, "test_backoff", "verifying exponential backoff");
    
    return 0;
}

int test_TAS1(int n_tests){
    
    char *test = "TAS";
    char subtest[MAX_DESCRIP];
    sprintf(subtest, "consequctive %d trials", n_tests);
    
    Lock tas;
    TAS_init(&tas);
    
    for (int i = 0; i < n_tests; i++){
        TAS_lock(&tas);
        TAS_unlock(&tas);
    }
    
    result(PASSED, test, subtest);
    
    return PASSED;
    
}

int test_threaded(char* test, int n_tests, int n_threads, Lock *lock, void*(*loop)(void*))
{
    char subtest[MAX_DESCRIP];
    sprintf(subtest, "%d threads %d trials", n_threads, n_tests);
    for (int k = 0; k < n_tests; k ++){
        long counter = 0;
        thread_arg_t ** threads;

        if (loop == &time_based_loop){
            START = 0;
            LOOP = 1;
            threads = create_thread_pool(lock, loop, &counter, n_threads);
            START = 1;
            usleep(20000);
            LOOP = 0;
            TIMEOUT(3, join_thread_pool(threads, n_threads));
        } else {
            N_PER_THREAD = 100000/n_threads/n_threads;
            threads = create_thread_pool(lock, loop, &counter, n_threads);
            TIMEOUT(6, join_thread_pool(threads, n_threads));
        }


        if (uerr){
            result(FAILED, test, subtest);
            return FAILED;
        }

        long test_counter = 0;
        for (int i = 0; i < n_threads; i ++){
            test_counter += threads[i]->test_counter;
        }
        
        if (test_counter - counter){
            result(FAILED, test, subtest);
            return 1;
        }

        free(threads);
    }
    result(PASSED, test, subtest);
    return PASSED;
}

int thread_battery(char *test, Lock *lock, void*(*loop)(void*))
{
    test_threaded(test, 1, 1, lock, loop);
    test_threaded(test, 1, 2, lock, loop);
    test_threaded(test, 1, 4, lock, loop);
    test_threaded(test, 1, 8, lock, loop);
    test_threaded(test, 1, 32, lock, loop);
    test_threaded(test, 5, 8, lock, loop);
    test_threaded(test, 10, 8, lock, loop);
    test_threaded(test, 23, 8, lock, loop);
    return 0;
}

int main(int argc, char* argv[])
{

    int all = 1;
    int null, mutex, tas, tasb, alock, clh;
    null = mutex = tasb = tas = alock = clh = 0;

    if (argc > 1){
        all = 0;
        if (!strcmp(argv[1], "all"))   all   = 1;
        if (!strcmp(argv[1], "null"))  null  = 1;
        if (!strcmp(argv[1], "mutex")) mutex = 1;
        if (!strcmp(argv[1], "tas"))   tas   = 1;
        if (!strcmp(argv[1], "tasb"))  tasb  = 1;
        if (!strcmp(argv[1], "alock")) alock = 1;
        if (!strcmp(argv[1], "clh"))   clh   = 1;
    }

    if (all){
        printf("Running all tests\n");
        test_TAS1(100);
        test_backoff();
    } else {
        printf("Running %s\n", argv[1]);
    }

    Lock lock;

    
    if (all || null){
        null_init(&lock);
        CATCH_ALL(thread_battery("no lock - timed", &lock, &time_based_loop));
        CATCH_ALL(thread_battery("no lock - worked", &lock, &work_based_loop));
    }

    if (all || mutex){
        mutex_init( &lock);
        CATCH_ALL(thread_battery("mutex - timed", &lock, &time_based_loop));
        CATCH_ALL(thread_battery("mutex - worked", &lock, &work_based_loop));
    }

    if (all || tas){
        TAS_init(&lock);
        CATCH_ALL(thread_battery("TAS - timed", &lock, &time_based_loop));
        CATCH_ALL(thread_battery("TAS - worked", &lock, &work_based_loop));
    }
    
    if (all || tasb){
        TASB_init(&lock, 1, 10);
        CATCH_ALL(thread_battery("TASB - timed", &lock, &time_based_loop));
        CATCH_ALL(thread_battery("TASB - worked", &lock, &work_based_loop));
    }

    if (all || alock){
        ALOCK_init( &lock, 32);
        CATCH_ALL(thread_battery("ALOCK - timed", &lock, &time_based_loop));
        CATCH_ALL(thread_battery("ALOCK - worked", &lock, &work_based_loop));
    }

    if (all || clh){
        CLH_init(&lock, 32);
        (thread_battery("CLH - timed", &lock, &time_based_loop));
        (thread_battery("CLH - worked", &lock, &work_based_loop));
    }

    return 0;
}


