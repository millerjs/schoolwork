#include <pthread.h>
#include <stdlib.h>

#include "../src/threads.h"
#include "../src/util.h"

#include "firewall.h"

volatile int LOOP_THREADS = 1;
volatile int N_PER_THREAD = 0;

volatile int LOOP = 0;
volatile int START = 0;

void *time_based_loop(void* _args_)
{
    
    thread_arg_t *args = (thread_arg_t*) _args_;
    Lock *lock = args->lock;
    int count = 0;

    while (!START) usleep(1);
    
    while (LOOP){
        lock->acquire(lock);
        *args->counter = *args->counter + 1;
        lock->release(lock);
        count += 1;
    }
    args->test_counter = count;

    return NULL;
}


void *work_based_loop(void* _args_)
{
    
    thread_arg_t *args = (thread_arg_t*) _args_;
    Lock *lock = args->lock;
    int count = 0;

    while (!START) usleep(1);
    
    while (count < N_PER_THREAD){
        lock->acquire(lock);
        *args->counter = *args->counter + 1;
        lock->release(lock);
        count ++;
    }
    args->test_counter = count;

    return NULL;
}

int join_thread_pool(thread_arg_t **threads, int n)
{
    int i;
    void *ret;
    for (i = 0; i < n; i++)
        pthread_join(*(threads[i]->this), &ret);
    return 0;
}

thread_arg_t **create_thread_pool(Lock *lock, loop_t loop, long *counter, int n)
{
    thread_arg_t **new = (thread_arg_t**) malloc(n*sizeof(thread_arg_t*));

    pthread_t *threads = (pthread_t*) malloc(n*sizeof(pthread_t));

    ERROR_IF(!threads, "unable to allocate memory for threads");

    if (lock)
        memset(lock->clh.ids, 0, sizeof(long)*MAX_THREADS);

    for (int i = 0; i < n; i++){
        new[i]               = malloc(sizeof(thread_arg_t));
        new[i]->counter      = NULL;
        new[i]->counter      = counter;
        new[i]->id           = i;
        new[i]->lock         = lock;
        new[i]->loop         = 0;
        new[i]->loop         = 1; 
        new[i]->n            = 10000;
        new[i]->nsources     = n;        
        new[i]->qs           = NULL;
        new[i]->test_counter = 0;
        new[i]->this         = &threads[i];

        int rs = pthread_create(&threads[i], NULL, loop, new[i]);
        ERROR_IF(rs, "unable to create thread\n");

        if (lock){
            lock->clh.ids[i] = threads[i];
            /* DEBUG("%li: ", lock->clh.ids[i]); */
        }

    }
    return new;
}

int assign_queues(Lock *locks, thread_arg_t ** threads, int n, LQ_t **qs, 
                  int numPackets)
{

    for (int i = 0; i < n; i++){
        qs[i]->npackets = numPackets;        
        qs[i]->ncomplete = 0;
        qs[i]->lock = &locks[i];
        for (int j = 0; j < threads[i]->nsources; j++){
            locks[j].clh.ids[i] = *threads[i]->this;
        }
        threads[i]->qs = qs;
    }
    return 0;
}

void start_threads()
{
    LOOP_THREADS = 1;
}

void stop_threads()
{
    LOOP_THREADS = 0;
}
