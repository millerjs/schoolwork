#ifndef LOCKS_H_
#define LOCKS_H_

#include <pthread.h>

typedef unsigned char TAS_t;

typedef union Lock {
    TAS_t tas;
    pthread_mutex_t mutex;
} Lock;

/* Test and Set */
int TAS_init(Lock *tas);
int TAS_lock(Lock *tas);
int TAS_unlock(Lock *tas);

int mutex_lock(Lock *lock);
int mutex_unlock(Lock *lock);


#endif

