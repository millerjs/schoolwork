#include <stdlib.h>
#include <ctype.h>
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <time.h>
#include <sys/types.h>
#include <sys/stat.h>

#include "threads.h"
#include "util.h"
#include "locks.h"
#include "../../utils/stopwatch.h"

#define MAX_PATH 1028

extern volatile int START;
extern volatile int LOOP;

double stddev = 0;


int open(char*path, char mode);

FILE *open_output_file(int experiment)
{
    long sec = time(NULL);
    char output_path[MAX_PATH];
    sprintf(output_path, "output/experiment_%d_%li.dat", experiment, sec);
    
    fprintf(stderr, "Writing output to [%s]\n", output_path);

    FILE *output_file = fopen(output_path, "w");
    if (!output_file){
        fprintf(stderr, "unable to open output file\n");
        exit(1);
    }
    return output_file;
}


long loop_threaded(int n_tests, int n_threads, Lock *lock, void*(*loop)(void*), int param1)
{
    long counter = 0;
    StopWatch_t timer;

    thread_arg_t ** threads = NULL;
    for (int k = 0; k < n_tests; k ++){
        if (loop == &time_based_loop){
            START = 0;
            LOOP = 1;
            threads = create_thread_pool(lock, loop, &counter, n_threads);
            START = 1;
            usleep(param1);
            LOOP = 0;
            join_thread_pool(threads, n_threads);
        } else {
            N_PER_THREAD = param1/n_threads;
            START = 0;
            LOOP = 1;
            threads = create_thread_pool(lock, loop, &counter, n_threads);
            startTimer(&timer);
            START = 1;
            join_thread_pool(threads, n_threads);
            stopTimer(&timer);
        }


    }
    if (loop == &time_based_loop){

        long count = 0;
 
        for (int i = 0; i < n_threads; i++){
            count += threads[i]->test_counter;
        }

        double sum = 0;
        double ave = (double)count / n_threads;
        for (int i = 0; i < n_threads; i++){
            sum += pow (threads[i]->test_counter - ave, 2.);
        }
        stddev = pow (sum/count, .5);

        fprintf(stderr, "stddev: %f\n", stddev);

        return counter / n_tests;


    } else {
        return (long)(getElapsedTime(&timer)*1000);
    }
}

/* Count based experiments */
int experiment1(FILE *output_file, int ms);
int experiment2(FILE *output_file, int count);
int experiment3(FILE *output_file);
int experiment4(FILE *output_file);
int experiment5(FILE *output_file);

/* Packet based experiments */
int experiment6(FILE *output_file);
int experiment7(FILE *output_file);
int experiment8(FILE *output_file);

double serialFirewall (int numPackets, int numSources, long mean, 
                       int uniformFlag, short experimentNumber);


long parallelFirewall (int numPackets, 
                         int numSources, 
                         long mean, 
                         int uniformFlag, 
                         short experimentNumber, 
                         void *(*loop)(void*),
                         Lock *locks);

int main(int argc, char* argv[])
{
    int c;
    opterr = 0;
    int experiment = 0;
    FILE *output_file;
    int ms = 100;
    int count = 2<<17;

    while ((c = getopt (argc, argv, "n:e:d:c:")) != -1){
        switch (c){
        case 'n':
            break;
        case 'e':
            ERROR_IF(sscanf(optarg, "%d", &experiment) != 1,
                     "-e expects an integer option\n");
            break;
        case 'm':
            ERROR_IF(sscanf(optarg, "%d", &ms) != 1,
                     "-m an integer millisecond specification\n");
        case 'c':
            ERROR_IF(sscanf(optarg, "%d", &count) != 1,
                     "-c an integer count specification\n");
        default:
            fprintf(stderr, "Unknown argument -%c\n", c);
            break;
            
        }
    }

    ERROR_IF(!experiment, "Please specify experiment number [-e]\n");

    fprintf(stderr, "Running Experiment %d\n", experiment);
    
    ERROR_IF(!(output_file = open_output_file(experiment)), 
             "unable to open output file");

    if (experiment == 1)          experiment1(output_file, ms);
    else if (experiment == 2)     experiment2(output_file, count);
    else if (experiment == 3)     experiment3(output_file);
    else if (experiment == 4)     experiment4(output_file);
    else if (experiment == 5)     experiment5(output_file);
    else if (experiment == 6)     experiment6(output_file);
    else if (experiment == 7)     experiment7(output_file);
    else if (experiment == 8)     experiment8(output_file);
    else
        ERROR("unknown experiment number");

    fclose(output_file);

    return 0;
    
}


