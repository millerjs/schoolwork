using namespace std;
#include <iostream>
#include <cstdlib>
#include <stdio.h>
#include <sstream>
#include <iostream>
#include <fstream>

#include "util.h"
#include "vector.h"
#include "matrix.h"

double theta = .5;
double mu    = .1;

#define N 100

#define LOOPIJ(f) do {                          \
        for (int i = 0; i < N; i++){            \
            for (int j = 0; j < N; j++){        \
                {f;}                            \
            }                                   \
        }                                       \
    } while (0)                                 \

#define FOR_EACH_N(f) do {                      \
        for (int i = 0; i < 4; i++){            \
            if (n[i]){                          \
                {f;}                            \
            }                                   \
        }                                       \
    } while (0)                                 \


matrix parseData(const char *path)
{
    FILE *input = fopen(path, "r");
    matrix ret(N, N, 0.0);
    LOOPIJ(ERROR_IF(!fscanf(input, "%lf", &ret[i][j]), "element read"));
    ret.normalize();
    return ret;
}

void writeData(const char *path, matrix a)
{
    ofstream dout;
    dout.open(path);
    for (int i = 0; i < N; i++){
        for (int j = 0; j < N; j++)
            dout << a[i][j] << " " ;
        dout << endl;
    }
    dout.close();
    return;
}

void ppm_out(const char *path, matrix a)
{
    ofstream pout;
    pout.open(path);
    pout << "P3" << endl;
    pout << N << " " << N << endl;
    pout << 1 << endl;
    LOOPIJ(int p = !!a[i][j]; pout << p << " " << p << " " << p << " " << endl);
    pout.close();
    return;
}


matrix add_noise(matrix a)
{
    matrix b = a.copy();
    srand(time(0));
    LOOPIJ(if (rand()/(double)RAND_MAX < mu) b[i][j] = !b[i][j]);
    return b;
}

double phi(double a, double b)
{
    if (a == b) return (1 + theta);
    return (1 - theta);
}


class node{
public:
    
    double y;
    node *n[4];
    matrix m_out;
    matrix m_in;
    
    node(){
        m_out = matrix(2, 4, 1.0);
        m_in  = matrix(2, 4, 1.0);
        FOR_EACH_N( n[i] = NULL; );
    }

    // calculate the product of all messages excluding on source
    double p(int x){
        double prod = 1;
        FOR_EACH_N( prod *= m_in[x][i]  );
        return prod * phi(y, x);
    }

    // calculate the product of all messages excluding on source
    double mproduct(int x, node *excluding){
        double prod = 1;
        FOR_EACH_N(  if (n[i] != excluding) prod *= m_in[x][i]  );
        return prod * phi(y, x);
    }
    
    // calculates the message to node b for xb = 0 or 1
    double m_t(int xb, node *b){
        return phi(0, xb) * mproduct(0, b) + phi(1, xb) * mproduct(1, b);
    }

    // computes the m_t matrix for outgoing messages for the node
    void compute_messages(){
        FOR_EACH_N(double m0 = m_t(0, n[i]);
                   double m1 = m_t(1, n[i]);
                   m_out[0][i] = m0 / (m0 + m1);
                   m_out[1][i] = m1 / (m0 + m1);
                   );
    }

    // makes messages for x_this = 0 and x_this = 1 and stores it to matchin m_1
    void receive(node *source, double m0, double m1){
        int idx;
        for (idx = 0; idx < 4; idx++) if (n[idx] == source) break;
        ERROR_IF(idx >= 4, "source is not neighbor of recipient");
        m_in[0][idx] = m0;
        m_in[1][idx] = m1;
    }

    // passes the outgoing message to each non-null neighbor
    void pass_messages(){
        FOR_EACH_N(  n[i]->receive(this, m_out[0][i], m_out[1][i])  );
    }

};

// assign each node in the graph its n
void setupGraph(node graph[N][N], matrix y)
{
    LOOPIJ(graph[i][j].y = y[i][j];
           if (i > 0)     graph[i][j].n[0] = &graph[i-1][j];
           if (j > 0)     graph[i][j].n[1] = &graph[i][j-1];
           if (j < N - 1) graph[i][j].n[2] = &graph[i][j+1];
           if (i < N - 1) graph[i][j].n[3] = &graph[i+1][j]);
}

void iterate(node graph[N][N])
{
    LOOPIJ(graph[i][j].compute_messages());
    LOOPIJ(graph[i][j].pass_messages());
}

matrix predict(node graph[N][N], matrix y)
{
    matrix xhat(N, N, 0.0);
    LOOPIJ(double x0 = graph[i][j].p(0);
           double x1 = graph[i][j].p(1);
           cout << x0 << " \t " << x1 << endl;
           if (x1 > x0) xhat[i][j] = 1.0;
           );
    return xhat;
}

int main (int argc, char *argv[])
{
    char path[1028];
    matrix a = parseData("data/square.data");
    matrix y = add_noise(a);

    ppm_out("output/predict0.ppm", y);
    ppm_out("output/original.ppm", a);

    node graph[N][N];
    setupGraph(graph, a);

    int iterations = 15;
    for(int i = 1; i <= iterations; i++){
        iterate(graph);
        matrix xhat = predict(graph, y);
        sprintf(path, "output/predicted_%04d.ppm", i);
        ppm_out(path, xhat);
        fprintf(stderr, "\r%d/%d", i, iterations);
    }    
    
    return 0;
}

