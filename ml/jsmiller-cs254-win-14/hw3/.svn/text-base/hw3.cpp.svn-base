using namespace std;
#include <iostream>
#include <cstdlib>
#include <stdio.h>
#include <sstream>
#include <iostream>
#include <fstream>

#include "util.h"
#include "vector.h"
#include "matrix.h"

double theta = -1;
double mu    = -1;

int N = 0;
int M = 0;

int X = 0;

#define LOOPIJ(f) do {                          \
        for (int i = 0; i < X; i++){            \
            for (int j = 0; j < X; j++){        \
                {f;}                            \
            }                                   \
        }                                       \
    } while (0)                                 \

#define FOR_EACH_N(f) do {                      \
        for (int i = 0; i < 4; i++){            \
            if (n[i]){                          \
                {f;}                            \
            }                                   \
        }                                       \
    } while (0)                                 \


matrix parseData(const char *path)
{
    FILE *input = fopen(path, "r");
    while (fgetc(input) != '\n') N++;
    N = (N+1)/2;
    fseek(input, 0, SEEK_SET);
    while (EOF != (fscanf(input, "%*[^\n]"), fscanf(input, "%*c"))) M++;
    fprintf(stderr, "Parsing Data: %d x %d\n", N, M);
    ERROR_IF(!N || !M, "File data must have non-zero dimensions");
    fseek(input, 0, SEEK_SET);
    X = N > M ? N : M;
    matrix ret(X, X, 0.0);
    LOOPIJ(ERROR_IF(!fscanf(input, "%lf", &ret[i][j]), "element read"));
    return ret;
}

void writeData(const char *path, matrix a)
{
    ofstream dout;
    dout.open(path);
    for (int i = 0; i < N; i++){
        for (int j = 0; j < M; j++)
            dout << a[i][j] << " " ;
        dout << endl;
    }
    dout.close();
    return;
}

void ppm_out(const char *path, matrix a)
{
    ofstream pout;
    pout.open(path);
    pout << "P3" << endl;
    pout << M << " " << N << endl;
    pout << 1 << endl;
    for (int i = 0; i < N; i++)
        for (int j = 0; j < M; j++){
            int p = !!a[i][j]; 
            pout << p << " " << p << " " << p << " " << endl;
        }
    pout.close();
    return;
}


matrix add_noise(matrix a)
{
    matrix b = a.copy();
    srand(time(0));
    LOOPIJ(if (rand()/(double)RAND_MAX < mu) b[i][j] = !b[i][j]);
    return b;
}

double phi(double a, double b)
{
    if (a == b) return (1 + theta);
    return (1 - theta);
}


class node{
public:
    
    double y;
    node *n[4];
    matrix m_out;
    matrix m_in;
    
    node(){
        m_out = matrix(2, 4, 1.0);
        m_in  = matrix(2, 4, 1.0);
        FOR_EACH_N( n[i] = NULL; );
    }

    // calculate the product of all messages excluding on source
    double p(int x){
        double prod = 1.0;
        FOR_EACH_N( prod *= m_in[x][i]  );
        return prod * phi(y, x);
    }

    // calculate the product of all messages excluding on source
    double mproduct(int x, node *excluding){
        double prod = 1.0;
        FOR_EACH_N(  if (n[i] != excluding) prod *= m_in[x][i]  );
        return prod * phi(y, x);
    }
    
    // calculates the message to node b for xb = 0 or 1
    double m_t(int xb, node *b){
        return phi(0, xb) * mproduct(0, b) + phi(1, xb) * mproduct(1, b);
    }

    // computes the m_t matrix for outgoing messages for the node
    void compute_messages(){
        FOR_EACH_N(double m0 = m_t(0, n[i]);
                   double m1 = m_t(1, n[i]);
                   m_out[0][i] = m0 / (m0 + m1);
                   m_out[1][i] = m1 / (m0 + m1);
                   );
    }

    // makes messages for x_this = 0 and x_this = 1 and stores it to matchin m_1
    void receive(node *source, double m0, double m1){
        int idx;
        for (idx = 0; idx < 4; idx++) if (n[idx] == source) break;
        m_in[0][idx] = m0;
        m_in[1][idx] = m1;
    }

    // passes the outgoing message to each non-null neighbor
    void pass_messages(){
        FOR_EACH_N(  n[i]->receive(this, m_out[0][i], m_out[1][i])  );
    }

};

// assign each node in the graph its n
void setupGraph(node **graph, matrix y)
{
    LOOPIJ(graph[i][j].y = y[i][j];
           if (i > 0)     graph[i][j].n[0] = &graph[i-1][j];
           if (j > 0)     graph[i][j].n[1] = &graph[i][j-1];
           if (i < X - 1) graph[i][j].n[3] = &graph[i+1][j];
           if (j < X - 1) graph[i][j].n[2] = &graph[i][j+1]);
}

void iterate(node **graph)
{
    LOOPIJ(graph[i][j].compute_messages());
    LOOPIJ(graph[i][j].pass_messages());
}

void predict(node **graph, matrix y, matrix x)
{
    LOOPIJ(x[i][j] = 0.0);
    LOOPIJ(double x0 = graph[i][j].p(0);
           double x1 = graph[i][j].p(1);
           if (x1 > x0) x[i][j] = 1.0;
           );
}


void run(matrix a, double m, double t)
{
    mu = m;
    theta = t;
    matrix y = add_noise(a);
    char path[1028];
    matrix x2(X, X, 0.0);
    matrix x1 = x2.copy();
    ppm_out("output/noisy.ppm", y);
    ppm_out("output/original.ppm", a);

    node **graph = new node*[X];
    for (int i = 0; i < N; i++)
        graph[i] = new node[X];

    setupGraph(graph, y);
    int i = 0;
    double sum = 1;

    while (sum && i < 150){
        iterate(graph);
        predict(graph, y, x2);
        matrix x3 = x1 - x2;
        x3.abs();
        sum = x3.sum();
        x1 = x2.copy();
        i++;
    }    

    matrix x3 = x2 - a;
    x3.abs();
    double errors = x3.sum();

    fprintf(stdout, "\r%.2lf\t%.2lf\t%i\t%.2lf\t%.2lf\n", 
            mu, theta, i, sum, errors);
    sprintf(path, "output/predicted_mu%.2lf_theta%.2lf.ppm", mu, theta);

    ppm_out(path, x2);
    writeData("output.data", x2);

    for (int i = 0; i < N; i++)
        delete [] graph[i];

    delete [] graph;
    
}

int main (int argc, char *argv[])
{

    char *path = NULL;
    int c;
     
    opterr = 0;
    while ((c = getopt (argc, argv, "m:t:f:")) != -1){
        switch (c) {
        case 't':
            ERROR_IF(1 != sscanf(optarg, "%lf", &theta), "parsing -t");
            break;
        case 'm':
            ERROR_IF(1 != sscanf(optarg, "%lf", &mu), "parsing -m");
            break;
        case 'f':
            path = strdup(optarg);
            break;
        default:
            ERROR("uknown option: %c", c);
        }
    }

    ERROR_IF(!path, "no input specified [-f]");
    matrix a = parseData(path);
    // fprintf(stderr, "\r%s\t%s\t%s\t%s\t%s\n", "mu", "theta", "iter", "sum", "diff");

    if (mu == -1 || theta == -1){
        WARN("-t theta or -m mu left unspecified: looping over all parameters");
        for (double m = .1; m <= .5 ; m += .1)
            for(double t = 0; t < 1; t += .05)
                run(a, m, t);
    } else {
        run(a, mu, theta);
    }
    
    return 0;
}

